#!/bin/bash
for i in {4..10}
do
    for j in {4..10}
    do
        echo "--- Running: d_model=$((2 ** i)), experts=$j ---"
        python main.py \
            --data_dir . \
            --text TFE-D_cfg2 \
            --audio AFE-B_cfg2 \
            --video VFE-A_cfg2 \
            --d_model $((2 ** i)) \
            --experts "$j" \
            --top_k 4 \
            --empathy_w 0.1 \
            --moe_w 0.01 \
            --epochs 30 \
            --batch_size 1 2>&1
    done
done | tee -a runner.log
